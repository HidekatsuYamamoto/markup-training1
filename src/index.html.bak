<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <title>山田花子のプロフィールページ</title>
    <meta
      name="description"
      content="マークアップトレーニング1を通してHTMLとCSSの基本を身につけましょう"
    />
    <link rel="stylesheet" href="css/reset.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:ital,wght@0,100..900;1,100..900&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="css/style.css">
  </head>
  <body>
    <div class="wrapper">
      <h1 class="name">山田 花子</h1>
      <div class="container">
        <div class="profile-img">
          <img src="img/profile_img.jpg" width="1520" height="864" alt="profiles picture">
        </div>
        <h2 class="profile">プロフィール</h2>
      </div>
    </div>
  </body>
</html>
